# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# LLM
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Vector DB (Pinecone)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=telehealth-diabetes-kb
PINECONE_ENVIRONMENT=us-east-1

# Database (inside Docker: host is "postgres"; locally use "localhost")
DATABASE_URL=postgresql+psycopg2://telehealth:telehealth$2026@postgres:5432/telehealth_db

# Redis (inside Docker: host is "redis"; locally use "localhost")
REDIS_URL=redis://redis:6379/0

# Mem0 (session memory)
MEM0_ENABLED=true

# Conversation context management
CONTEXT_TOKEN_LIMIT=2000
CONTEXT_MAX_RAW_MESSAGES=5

# Telegram Bot (get token from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ENABLED=false

# Data paths
RULES_DIR=../../data/rules
